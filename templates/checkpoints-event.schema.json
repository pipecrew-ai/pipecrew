{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pipecrew/checkpoints-event.schema.json",
  "title": "Feature-pipeline checkpoint event",
  "description": "One line in runs/{skill}/{run_id}/checkpoints.jsonl. See rules/observability.md for prose spec.",
  "type": "object",
  "required": ["ts", "event", "skill", "run_id"],
  "properties": {
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO8601 UTC emission time"
    },
    "event": {
      "enum": ["run_start", "run_end", "phase_start", "phase_end", "agent_end", "orch_checkpoint", "bash_slow", "retry"]
    },
    "skill": {
      "enum": ["discover", "deliver", "learn", "review", "assess", "context-refresh", "onboard", "feature"],
      "description": "Skill that owns the run. `onboard` / `feature` are legacy aliases kept for pre-rename checkpoints (renamed to `discover` / `deliver` respectively)."
    },
    "run_id": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}-\\d{6}-[a-z0-9][a-z0-9-]*(-\\d+)?$",
      "description": "{YYYY-MM-DD-HHMMSS}-{slug} with optional -N collision suffix"
    },
    "phase": { "type": "string" },
    "stage": { "type": "string" }
  },
  "allOf": [
    {
      "if": { "properties": { "event": { "const": "run_start" } } },
      "then": {
        "required": ["workspace_slug"],
        "properties": {
          "workspace_slug": { "type": "string" },
          "args": { "type": "string" },
          "claude_code_version": { "type": "string" }
        }
      }
    },
    {
      "if": { "properties": { "event": { "const": "run_end" } } },
      "then": {
        "required": ["status", "duration_ms"],
        "properties": {
          "status": { "enum": ["completed", "failed", "aborted", "resumed_later"] },
          "duration_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "if": { "properties": { "event": { "const": "phase_start" } } },
      "then": {
        "required": ["phase", "stage"]
      }
    },
    {
      "if": { "properties": { "event": { "const": "phase_end" } } },
      "then": {
        "required": ["phase", "stage", "duration_ms"],
        "properties": {
          "duration_ms": { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "if": { "properties": { "event": { "const": "agent_end" } } },
      "then": {
        "required": ["agent_type", "description", "status"],
        "properties": {
          "agent_type": { "type": "string" },
          "description": { "type": "string" },
          "status": { "enum": ["ok", "retry", "failed", "deferred"] },
          "input_tokens": { "type": "integer", "minimum": 0 },
          "output_tokens": { "type": "integer", "minimum": 0 },
          "cache_read_tokens": { "type": "integer", "minimum": 0 },
          "cache_write_tokens": { "type": "integer", "minimum": 0 },
          "total_tokens": { "type": "integer", "minimum": 0 },
          "tool_uses": { "type": "integer", "minimum": 0 },
          "duration_ms": { "type": "integer", "minimum": 0 },
          "audit_findings_count": { "type": "integer", "minimum": 0 }
        }
      }
    },
    {
      "if": { "properties": { "event": { "const": "orch_checkpoint" } } },
      "then": {
        "required": ["jsonl_offset", "orch_since_last"],
        "properties": {
          "jsonl_offset": { "type": "integer", "minimum": 0 },
          "orch_since_last": {
            "type": "object",
            "required": ["input_tokens", "output_tokens"],
            "properties": {
              "input_tokens": { "type": "integer", "minimum": 0 },
              "output_tokens": { "type": "integer", "minimum": 0 },
              "cache_read_tokens": { "type": "integer", "minimum": 0 }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "event": { "const": "bash_slow" } } },
      "then": {
        "required": ["duration_ms", "cmd_summary"],
        "properties": {
          "duration_ms": { "type": "integer", "minimum": 5000 },
          "cmd_summary": { "type": "string", "maxLength": 60 }
        }
      }
    },
    {
      "if": { "properties": { "event": { "const": "retry" } } },
      "then": {
        "required": ["agent_type", "description", "retry_reason"],
        "properties": {
          "agent_type": { "type": "string" },
          "description": { "type": "string" },
          "retry_reason": { "type": "string" }
        }
      }
    }
  ]
}
