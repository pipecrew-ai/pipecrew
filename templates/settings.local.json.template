{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "_generated_by": "/discover for workspace {{WORKSPACE_SLUG}} on {{DATE}}",
  "permissions": {
    "allow": [
      "Edit({workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Write({workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Read({workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Bash(mkdir -p {workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Bash(cat {workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Bash(ls {workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Bash(find {workspace_root}/{{WORKSPACE_SLUG}}/**)",
      "Edit(~/.claude/agents/{{WORKSPACE_SLUG}}-*.md)",
      "Write(~/.claude/agents/{{WORKSPACE_SLUG}}-*.md)",

      "Bash(node {{PLUGIN_DIR}}/scripts/validate-config.js:*)",
      "Bash(node {{PLUGIN_DIR}}/scripts/validate-claude-md.js:*)",
      "Bash(node {{PLUGIN_DIR}}/scripts/validate-checkpoints.js:*)",
      "Read({{PLUGIN_DIR}}/**)",

{{REPO_ALLOW_ENTRIES}}
      "Bash(date *)",
      "Bash(openssl rand *)",
      "Bash(git worktree list*)",
      "Bash(git worktree add*)",
      "Bash(git worktree remove*)"
    ]
  }
}
