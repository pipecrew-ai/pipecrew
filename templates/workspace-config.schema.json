{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Feature Pipeline Workspace Config",
  "description": "Generated by /init. Lives at ~/.claude/{workspace-slug}-config.json. Never committed to any repo (contains absolute paths).",
  "type": "object",
  "required": ["workspace", "repos", "services"],
  "properties": {
    "workspace": {
      "type": "object",
      "required": ["name", "slug"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Human-readable workspace name"
        },
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Kebab-case slug used in file paths and pipeline dirs"
        },
        "pipeline_dir": {
          "type": "string",
          "description": "Override pipeline scratchpad location. Default: ~/.claude/workspaces/{slug}/pipeline"
        },
        "primary_language": {
          "type": "string",
          "default": "en",
          "description": "Primary UI language (en, ar, etc.)"
        }
      }
    },
    "repos": {
      "type": "object",
      "description": "Map of repo short-name → repo config. Each key is a unique identifier used internally.",
      "additionalProperties": {
        "type": "object",
        "required": ["path", "type", "role"],
        "properties": {
          "path": {
            "type": "string",
            "description": "Absolute path to the repo root on disk"
          },
          "type": {
            "type": "string",
            "enum": ["spring-boot", "react", "nextjs", "nestjs", "fastapi", "node-mock", "cdk", "other"],
            "description": "Tech stack type — drives agent selection"
          },
          "role": {
            "type": "string",
            "enum": ["api-service", "frontend", "mock-server", "infrastructure", "shared-lib", "other"],
            "description": "Architectural role of this repo"
          },
          "description": {
            "type": "string",
            "description": "One-line description of what this repo does"
          },
          "spec_file": {
            "type": "string",
            "description": "Path to the OpenAPI spec file relative to repo root (for api-service repos)"
          },
          "spec_copies": {
            "type": "object",
            "description": "Map of service-name → relative path where this repo keeps a copy of that service's spec",
            "additionalProperties": { "type": "string" }
          }
        }
      }
    },
    "services": {
      "type": "object",
      "description": "Map of service short-name → service config. Services are the logical API boundaries the pipeline operates on.",
      "additionalProperties": {
        "type": "object",
        "required": ["repo"],
        "properties": {
          "repo": {
            "type": "string",
            "description": "Key in the repos map that holds this service"
          },
          "spec_file": {
            "type": "string",
            "description": "Spec file path relative to the repo root (overrides repo-level spec_file)"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "domain": {
      "type": "object",
      "description": "Domain knowledge block. Optional — enriched by /init Phase B2.",
      "properties": {
        "name": { "type": "string" },
        "primary_entities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "user_roles": {
          "type": "array",
          "items": { "type": "string" }
        },
        "auth_type": {
          "type": "string",
          "enum": ["jwt", "session", "api-key", "oauth2", "none"]
        },
        "i18n_languages": {
          "type": "array",
          "items": { "type": "string" }
        },
        "rtl_support": { "type": "boolean" },
        "domain_notes": { "type": "string" }
      }
    }
  }
}
